{
  "name": "idr-exchange-rates",
  "displayName": "IDR Exchange Rates",
  "description": "Personal learning project: Bun + Elysia API that scrapes Indonesian bank sites and returns IDR exchange rates as JSON (BCA, BI, BNI, BRI, Mandiri). OpenAPI docs, CORS, short response cache—not a production or commercial service.",
  "version": "2.1.0",
  "author": {
    "name": "k-ardliyan",
    "url": "https://github.com/k-ardliyan"
  },
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "start": "NODE_ENV=production bun src/index.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "cheerio": "^1.2.0",
    "elysia": "latest"
  },
  "devDependencies": {
    "bun-types": "latest"
  },
  "engines": {
    "node": "latest",
    "bun": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k-ardliyan/idr-exchange-rates.git"
  },
  "bugs": {
    "url": "https://github.com/k-ardliyan/idr-exchange-rates/issues"
  },
  "homepage": "https://github.com/k-ardliyan/idr-exchange-rates#readme",
  "keywords": [
    "indonesia",
    "rupiah",
    "exchange-rates",
    "currency",
    "api",
    "web-scraper",
    "financial",
    "data",
    "exchange"
  ]
}
